# Public guest instance.
# Copy to .env.public and fill the API key before starting.

PUBLIC_WEBUI_PORT=3001

# Public instance has no login. Only upload documents that are safe for visitors.
WEBUI_AUTH=False
ENABLE_SIGNUP=False
WEBUI_NAME=在线问答

ENABLE_OPENAI_API=true
MODEL_PROVIDER_NAME=deepseek
# The public instance goes through a local cache proxy to save tokens on repeated identical answers.
OPENAI_API_BASE_URL=http://token-cache-proxy:8000/v1
OPENAI_API_KEY=sk-your-deepseek-api-key
OPENAI_MODEL=deepseek-chat
UPSTREAM_BASE_URL=https://api.deepseek.com/v1
CACHE_TTL_SECONDS=604800

# Public no-login users share one Open WebUI backend user. Keep public chats short-lived.
PUBLIC_CHAT_RETENTION_SECONDS=60

# Visitor chat should open with the public knowledge-base assistant.
# Visitors receive the custom model from public-loader.js. Keep server defaults
# empty so Open WebUI never tries to resolve the custom ID as a base provider.
DEFAULT_MODELS=
DEFAULT_PINNED_MODELS=
ENABLE_CUSTOM_MODEL_FALLBACK=False
MODEL_FILTER_LIST=
BYPASS_MODEL_ACCESS_CONTROL=False
RESET_CONFIG_ON_START=true

WEBUI_SECRET_KEY=change-this-public-instance-secret
